# FitDuo environment variables (CLAUDE.md §9). Copy to .env.local and fill in.
# NEXT_PUBLIC_* values are exposed to the browser; everything else is server-only.

# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=       # server only

# App
NEXT_PUBLIC_APP_TZ=Asia/Kolkata

# Web Push (VAPID) — generate with: npx web-push generate-vapid-keys
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=               # server only

# Reminder cron endpoint protection
CRON_SECRET=                     # protects the cron route

# Phase 2 (server only)
ANTHROPIC_API_KEY=               # Phase 2, server only
